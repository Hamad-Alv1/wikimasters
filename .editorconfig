
# EditorConfig for repository
root = true

[*.{js,jsx,ts,tsx,py,java,cs,cpp,c,h,html,css,scss,sass,md,json,yml,yaml,xml,ini,sh,ps1,rs,go}]
indent_style = space
indent_size = 2
tab_width = 2

[*.{md,txt}]
trim_trailing_whitespace = false

[*.json]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

# Common settings
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
